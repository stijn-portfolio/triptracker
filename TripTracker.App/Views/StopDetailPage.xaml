<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TripTracker.App.Views.StopDetailPage"
             Title="{Binding CurrentStop.Title}">

    <!-- Detail pagina voor een TripStop -->

    <ScrollView Padding="15">
        <VerticalStackLayout Spacing="15">

            <!-- Foto -->
            <Image Source="{Binding CurrentStop.PhotoUrl}"
                   HeightRequest="250"
                   Aspect="AspectFill"/>

            <!-- Beschrijving (titel via ContentPage.Title) -->
            <Label Text="{Binding CurrentStop.Description}"
                   FontSize="16"/>

            <!-- Locatie info -->
            <Border Stroke="LightGray" Padding="10" BackgroundColor="Transparent" StrokeShape="RoundRectangle 8">
                <Grid RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="8">
                    <Label Text="Location"
                           FontSize="16"
                           FontAttributes="Bold"
                           Grid.Row="0"/>

                    <Label Text="{Binding CurrentStop.Address}"
                           FontSize="14"
                           LineBreakMode="WordWrap"
                           Grid.Row="1"/>

                    <Label Text="{Binding CurrentStop.Country}"
                           FontSize="14"
                           TextColor="Gray"
                           Grid.Row="2"/>

                    <HorizontalStackLayout Spacing="20" Grid.Row="3">
                        <Label Text="{Binding CurrentStop.Latitude, StringFormat='Lat: {0:F6}'}"
                               FontSize="12"
                               TextColor="DarkGray"/>
                        <Label Text="{Binding CurrentStop.Longitude, StringFormat='Lng: {0:F6}'}"
                               FontSize="12"
                               TextColor="DarkGray"/>
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <!-- DateTime (escape 'om' met backslash om format parsing te vermijden) -->
            <Label Text="{Binding CurrentStop.DateTime, StringFormat='Visited: {0:dd MMMM yyyy} - {0:HH:mm}'}"
                   FontSize="14"
                   TextColor="Gray"/>

            <!-- Map button -->
            <Button Text="🌍 Show on Map"
                    Command="{Binding ShowStopOnMapCommand}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    Margin="0,10,0,0"/>

            <!-- Action buttons -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,10,0,0">
                <Button Text="Edit"
                        Command="{Binding EditCommand}"
                        BackgroundColor="DarkBlue"
                        TextColor="White"/>
                <Button Text="Delete"
                        Command="{Binding DeleteCommand}"
                        Grid.Column="1"
                        BackgroundColor="Red"
                        TextColor="White"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
